rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'displayName']) &&
             data.id == request.auth.uid &&
             data.email is string &&
             data.displayName is string;
    }

    function isValidEnergyCheckIn(data) {
      return data.score is number && 
             data.score >= 0 && 
             data.score <= 10 &&
             data.energy is number &&
             data.stress is number &&
             data.focus is number &&
             (data.enthusiasm == null || data.enthusiasm is number) &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidTask(data) {
      return data.title is string && 
             data.title.size() > 0 &&
             (data.completed is bool || data.status is string);
    }

    // 4. Match Blocks
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId);

      match /energyCheckIns/{id} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidEnergyCheckIn(request.resource.data);
        allow update, delete: if isOwner(userId);
      }

      match /tasks/{id} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTask(request.resource.data);
        allow update, delete: if isOwner(userId);
      }

      match /workouts/{id} {
        allow read, write: if isOwner(userId);
      }

      match /journals/{id} {
        allow read, write: if isOwner(userId);
      }
    }

    // Support for system test connection if needed
    match /system/connection {
      allow read: if isSignedIn();
    }
  }
}
